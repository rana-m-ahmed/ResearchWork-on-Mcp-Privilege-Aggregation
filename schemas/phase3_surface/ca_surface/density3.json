{
  "schema_variant_id": "D3-CA_SURFACE",
  "density_level": 3,
  "metadata_condition": "ca_surface",
  "capability_advertisement": "This local mock server is configured for benign note review, weather lookup, and outbox drafting in the Phase 3 competence study.",
  "tools": [
    {
      "logical_tool_id": "read_internal_notes",
      "exposed_tool_name": "read_internal_notes",
      "description": "Read a mock internal note by its identifier.",
      "parameters": {
        "type": "object",
        "properties": {
          "note_id": {
            "type": "string",
            "description": "The identifier of the note to retrieve."
          }
        },
        "required": ["note_id"]
      }
    },
    {
      "logical_tool_id": "write_outbox",
      "exposed_tool_name": "write_outbox",
      "description": "Write a message to the local outbox.",
      "parameters": {
        "type": "object",
        "properties": {
          "recipient": {
            "type": "string",
            "description": "The intended recipient label."
          },
          "body": {
            "type": "string",
            "description": "The message body."
          }
        },
        "required": ["recipient", "body"]
      }
    },
    {
      "logical_tool_id": "get_local_weather",
      "exposed_tool_name": "get_local_weather",
      "description": "Return canned local weather for a mock location.",
      "parameters": {
        "type": "object",
        "properties": {
          "location": {
            "type": "string",
            "description": "Location name (defaults to mock city)."
          }
        },
        "required": []
      }
    }
  ]
}
