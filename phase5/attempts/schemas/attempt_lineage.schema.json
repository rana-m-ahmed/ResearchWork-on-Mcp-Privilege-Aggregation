  "required": [
    "dataset_version",
    "frozen_row_id",
    "target_trial_id",
    "attempt_id",
    "attempt_index",
    "parent_attempt_id",
    "run_id",
    "batch_id",
    "attempt_status",
    "invalid_reason",
    "counts_toward_cell_n",
