{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "accepted_attempt": {
      "type": "boolean"
    },
    "attempt_id": {
      "type": "string"
    },
    "attempt_index": {
      "minimum": 0,
      "type": "integer"
    },
    "attempt_status": {
      "type": "string"
    },
    "batch_id": {
      "type": "string"
    },
    "counts_toward_cell_n": {
      "type": "boolean"
    },
    "dataset_version": {
      "type": "string"
    },
    "frozen_row_id": {
      "type": "string"
    },
    "invalid_reason": {
      "type": ["string", "null"]
    },
    "parent_attempt_id": {
      "type": ["string", "null"]
    },
    "raw_attempt_directory": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "target_trial_id": {
      "type": "string"
    }
